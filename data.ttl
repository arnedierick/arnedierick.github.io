@prefix vc: <https://arnedierick.github.io/vocab.ttl#> .
@prefix dt: <https://arnedierick.github.io/data.ttl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dt:me a vc:Student ;
    vc:name "Arne Dierick" ;
    vc:studentId "02003694" ;
    vc:hasPassion dt:football, dt:chess ;
    vc:birthYear "2002"^^xsd:gYear  ;
    vc:hasFriend <https://vucis.github.io/data.ttl#me> ,
                 <https://miboelae.github.io/data.ttl#me> .

dt:aldrin a vc:Person ;
          vc:name "Buzz Aldrin" .

dt:armstrong a vc:Person ;
             vc:name "Neil Armstrong" .

dt:leifer a vc:Person ;
          vc:name "Neil Leifer" .

dt:ali a vc:Person ;
       vc:name "Muhammad Ali" .

dt:liston a vc:Person ;
          vc:name "Sonny Liston" .

dt:sasse a vc:Person ;
         vc:name "Arthur Sasse" .

dt:einstein a vc:Person ;
            vc:name "Albert Einstein" .

dt:football a vc:Hobby ;
    rdfs:label "Football"@en ;
    rdfs:comment "A game where you kick a ball into a goal"@en .

dt:chess a vc:Hobby ;
    rdfs:label "Chess"@en ;
    rdfs:comment "A strategic game where you move different pieces on a board to checkmate your opponent"@en .

dt:gent a vc:Location ;
        rdfs:label "Gent"@nl, "Ghent"@en, "Gand"@fr ;
        rdfs:comment "The medieval Belgian town where the rivers Scheldt and Lys meet"@en .

dt:moon a vc:Location ;
        rdfs:label "Maan"@nl , "Moon"@en ;
        rdfs:comment "The extraterrestrial body that orbits the earth"@en .

dt:lewiston a vc:Location ;
            rdfs:label "Lewiston"@en ;
            rdfs:comment "A city in Maine in Androscoggin County"@en .

dt:princeton a vc:Location ;
             rdfs:label "Princeton"@en ;
             rdfs:comment "A borough in Mercer County in the state of New Jersey"@en .

<https://vtk.ugent.be/media/thumbs/photologue/photos/jobfair-2026-cv-fotos_95_r6m33397.jpg.1920x1005_q85_crop-scale.jpg> a vc:Image ;
    vc:title "CV foto Arne Dierick Jobfair 2026" ;
    vc:creator "VTK Gent" ;
    vc:features dt:me ;
    vc:shotAt dt:gent ;
    vc:description "A professional photo taken at the VTK Jobfair 2026 that features Arne Dierick"@en .

<https://www.nasa.gov/wp-content/uploads/2019/07/edu_srch_celebrate_the_50th_anniversary_apollo11.jpg?w=1024> a vc:Image ;
    vc:title "Apollo 11 astronaut with flag" ;
    vc:creator dt:armstrong ;
    vc:features dt:aldrin ;
    vc:shotAt dt:moon ;
    vc:description "A photo of Astronaut Buzz Aldrin taken on the moon by Neil Armstrong during the Apollo 11 moon landing" .

<https://i.guim.co.uk/img/media/7fa6a03e6a72421c0b2f40352ce1a423e6297974/0_0_3565_3019/master/3565.jpg?width=1900&dpr=1&s=none&crop=none> a vc:Image ;
    vc:title "Ali KOs Liston" ;
    vc:creator dt:leifer ;
    vc:features dt:ali, dt:liston ;
    vc:shotAt dt:lewiston ;
    vc:description "Muhammad Ali stands over Sonny Liston while boasting in the ring" .

<https://upload.wikimedia.org/wikipedia/commons/thumb/4/46/Albert_Einstein_sticks_his_tongue.jpg/500px-Albert_Einstein_sticks_his_tongue.jpg> a vc:Image ;
    vc:title "Albert Einstein sticking out tongue" ;
    vc:creator dt:sasse ;
    vc:features dt:einstein ;
    vc:shotAt dt:princeton ;
    vc:description "Scientist Albert Einstein sticking out his tongue at his 72nd birthday party" .
