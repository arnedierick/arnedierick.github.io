@prefix vc: <https://arnedierick.github.io/vocab.ttl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .


vc:Person a rdfs:Class ;
          rdfs:subClassOf foaf:Person ;
          rdfs:label "Person"@en ;
          rdfs:comment "A human being."@en .

vc:Student a rdfs:Class ;
           rdfs:subClassOf vc:Person ;
           rdfs:label "Student"@en ;
           rdfs:comment "A person enrolled at an educational institution."@en .

vc:Hobby a rdfs:Class ;
         rdfs:label "Hobby"@en ;
         rdfs:comment "An activity that a person enjoys doing in their free time."@en .

vc:Image a rdfs:Class ;
         rdfs:subClassOf foaf:Image ;
         rdfs:label "Image"@en ;
         rdfs:comment "A visual illustration of an object"@en .

vc:Location a rdfs:Class ;
            rdfs:label "Location"@en ;
            rdfs:comment "The location of an object"@en .

vc:name a rdf:Property ;
        rdfs:subPropertyOf  foaf:name ;
        rdfs:label "name"@en ;
        rdfs:comment "The full name of a person."@en ;
        rdfs:domain vc:Person ;
        rdfs:range xsd:string .

vc:studentId a rdf:Property ;
             rdfs:label "student ID"@en ;
             rdfs:comment "The official student identification number."@en ;
             rdfs:domain vc:Student ;
             rdfs:range xsd:string .

vc:birthYear a rdf:Property ;
             rdfs:label "birth year"@en ;
             rdfs:comment "The year in which a person was born."@en ;
             rdfs:domain vc:Person ;
             rdfs:range xsd:gYear .

vc:hasPassion a rdf:Property ;
              rdfs:label "has passion"@en ;
              rdfs:comment "Relates a person to a hobby they are passionate about."@en ;
              rdfs:domain vc:Person ;
              rdfs:range vc:Hobby .

vc:hasFriend a rdf:Property ;
             rdfs:subPropertyOf foaf:knows ;
             rdfs:label "has friend"@en ;
             rdfs:comment "Relates a person to another person they are friends with."@en ;
             rdfs:domain vc:Person ;
             rdfs:range vc:Person .

vc:title a rdf:Property ;
         rdfs:label "title"@en ;
         rdfs:comment "The title of the subject"@en ;
         rdfs:range xsd:string .

vc:creator a rdf:Property ;
           rdfs:subPropertyOf foaf:maker ;
           rdfs:label "Creator"@en ;
           rdfs:comment "The creator of this object"@en .

vc:features a rdf:Property ;
            rdfs:subPropertyOf foaf:depicts ;
            rdfs:label "features"@en ;
            rdfs:comment "shows that the object is featured in the subject"@en ;
            rdfs:domain vc:Image ;
            rdfs:range vc:Person .

vc:shotAt a rdf:Property ;
             rdfs:label "shot at"@en ;
             rdfs:comment "relates a photo to the place it was shot" ;
             rdfs:domain vc:Image ;
             rdfs:range vc:Location .

vc:description a rdf:Property ;
               rdfs:label "description"@en ;
               rdfs:comment "a short summary of the subject"@en ;
               rdfs:range xsd:string .
